{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4lpha.tech/schemas/strategy-spec.schema.json",
  "title": "FourMemeStrategySpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "strategyId",
    "generatedAt",
    "domain",
    "status",
    "inputWindow",
    "universe",
    "regime",
    "entryRules",
    "exitRules",
    "riskControls",
    "invalidation",
    "assumptions",
    "evidence",
    "strategyThesis",
    "brainReview",
    "rationale"
  ],
  "properties": {
    "artifactRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactRef"
      }
    },
    "dataQuality": {
      "$ref": "#/$defs/dataQuality"
    },
    "onchainEnrichment": {
      "$ref": "#/$defs/onchainEnrichment"
    },
    "skillRoute": {
      "$ref": "#/$defs/skillRoute"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "strategyId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "domain": {
      "type": "string",
      "enum": [
        "bnb-fourmeme"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "rejected"
      ]
    },
    "inputWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asOf",
        "barInterval",
        "lookback"
      ],
      "properties": {
        "asOf": {
          "type": "string",
          "format": "date-time"
        },
        "barInterval": {
          "type": "string",
          "minLength": 1
        },
        "lookback": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "universe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chain",
        "venue",
        "selectionMethod",
        "quoteAsset",
        "candidateCount"
      ],
      "properties": {
        "chain": {
          "type": "string",
          "enum": [
            "bnb-chain"
          ]
        },
        "venue": {
          "type": "string",
          "enum": [
            "fourmeme"
          ]
        },
        "selectionMethod": {
          "type": "string",
          "minLength": 1
        },
        "quoteAsset": {
          "type": "string",
          "minLength": 1
        },
        "candidateCount": {
          "type": "integer",
          "minimum": 0
        },
        "bucketCounts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "safe2ape",
            "mediumRisk",
            "gemHunt"
          ],
          "properties": {
            "safe2ape": {
              "type": "integer",
              "minimum": 0
            },
            "mediumRisk": {
              "type": "integer",
              "minimum": 0
            },
            "gemHunt": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "sampleCandidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidate"
          }
        }
      }
    },
    "regime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "summary"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "entryRules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      },
      "minItems": 1
    },
    "exitRules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      },
      "minItems": 1
    },
    "riskControls": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/riskControl"
      },
      "minItems": 1
    },
    "invalidation": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/condition"
      },
      "minItems": 1
    },
    "assumptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assumption"
      },
      "minItems": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      },
      "minItems": 1
    },
    "strategyThesis": {
      "type": "string",
      "minLength": 1
    },
    "brainReview": {
      "$ref": "#/$defs/brainReview"
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "rejectionReasons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/condition"
      }
    }
  },
  "$defs": {
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "path",
        "role",
        "sha256"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "input",
            "output",
            "summary"
          ]
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "dataQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness",
        "providerErrors",
        "status",
        "summary"
      ],
      "properties": {
        "freshness": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/freshnessRecord"
          }
        },
        "providerErrors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/providerError"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "complete",
            "partial",
            "degraded",
            "failed"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "skillRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalogSource",
        "catalogVersion",
        "optionalEnrichments",
        "query",
        "rejectedSkills",
        "requiredInputs",
        "routeStatus",
        "routeType",
        "routedAt",
        "routingReason",
        "selectedSkill",
        "selectedSkillLabel",
        "selectedSkillRole",
        "skillExecution"
      ],
      "properties": {
        "catalogSource": {
          "type": "string",
          "minLength": 1
        },
        "catalogVersion": {
          "type": "string",
          "minLength": 1
        },
        "optionalEnrichments": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "query": {
          "type": "string",
          "minLength": 1
        },
        "rejectedSkills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rejectedSkillRoute"
          }
        },
        "requiredInputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "routeStatus": {
          "type": "string",
          "enum": [
            "primary_selected",
            "context_only",
            "no_match"
          ]
        },
        "routeType": {
          "type": "string",
          "enum": [
            "find_skill-local-contract"
          ]
        },
        "routedAt": {
          "type": "string",
          "format": "date-time"
        },
        "routingReason": {
          "type": "string",
          "minLength": 1
        },
        "selectedSkill": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "selectedSkillLabel": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "selectedSkillRole": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "context",
            "data",
            "onchain-advisory",
            "onchain-entry-quality",
            "onchain-risk",
            "primary",
            "research",
            null
          ]
        },
        "skillExecution": {
          "$ref": "#/$defs/skillExecution"
        }
      }
    },
    "rejectedSkillRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "skillId"
      ],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "skillId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "onchainEnrichment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asOf",
        "candidates",
        "dataQuality",
        "skillExecution",
        "skills",
        "source",
        "summary"
      ],
      "properties": {
        "asOf": {
          "type": "string",
          "format": "date-time"
        },
        "candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/onchainCandidateReview"
          }
        },
        "dataQuality": {
          "$ref": "#/$defs/dataQuality"
        },
        "proofRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/onchainProofRef"
          }
        },
        "skillExecution": {
          "$ref": "#/$defs/skillExecution"
        },
        "skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/onchainSkillId"
          }
        },
        "source": {
          "type": "string",
          "enum": [
            "cmc-skills-marketplace-fixture",
            "cmc-skills-marketplace-live",
            "cmc-skills-marketplace-recorded-remote",
            "unavailable"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "onchainCandidateReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aggregateRisk",
        "eligibleForEntry",
        "positionSizeMultiplier",
        "reviews",
        "symbol",
        "tokenAddress"
      ],
      "properties": {
        "addressProvenance": {
          "type": "string",
          "enum": [
            "deterministic-fixture-address",
            "live-fourmeme-contract",
            "recorded-fourmeme-contract"
          ]
        },
        "aggregateRisk": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical",
            "unknown"
          ]
        },
        "eligibleForEntry": {
          "type": "boolean"
        },
        "positionSizeMultiplier": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reviews": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/onchainSkillReview"
          },
          "minItems": 1
        },
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "tokenAddress": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        }
      }
    },
    "onchainProofRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundlePath",
        "mode",
        "proofSha256",
        "skillId",
        "tokenAddress"
      ],
      "properties": {
        "bundlePath": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "live-execution",
            "recorded-remote"
          ]
        },
        "proofSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "skillId": {
          "$ref": "#/$defs/onchainSkillId"
        },
        "tokenAddress": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        }
      }
    },
    "onchainSkillReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metrics",
        "observedAt",
        "role",
        "skillId",
        "status",
        "summary"
      ],
      "properties": {
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "string",
              "boolean"
            ]
          }
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "role": {
          "type": "string",
          "enum": [
            "hard-risk-gate",
            "entry-quality-gate",
            "advisory-confidence"
          ]
        },
        "skillId": {
          "$ref": "#/$defs/onchainSkillId"
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "warning",
            "failed",
            "unavailable"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "onchainSkillId": {
      "type": "string",
      "enum": [
        "review_dex_wallet_activity_profile",
        "review_dex_wallet_pnl",
        "score_holder_concentration_risk"
      ]
    },
    "skillExecution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "reason",
        "status"
      ],
      "properties": {
        "endpointName": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "live-execution",
            "local-contract",
            "live-probe",
            "recorded",
            "recorded-remote"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "sourceUrl": {
          "type": "string",
          "format": "uri"
        },
        "status": {
          "type": "string",
          "enum": [
            "matched",
            "unavailable",
            "failed"
          ]
        }
      }
    },
    "freshnessRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expectedCadence",
        "retrievedAt"
      ],
      "properties": {
        "expectedCadence": {
          "type": "string",
          "minLength": 1
        },
        "retrievedAt": {
          "type": "string",
          "format": "date-time"
        },
        "sourceObservedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "providerError": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message",
        "observedAt",
        "recoverable",
        "source"
      ],
      "properties": {
        "endpoint": {
          "type": "string"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "recoverable": {
          "type": "boolean"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string"
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "metric",
        "operator",
        "value"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "operator": {
          "type": "string",
          "enum": [
            ">",
            ">=",
            "<",
            "<=",
            "=",
            "crosses_above",
            "crosses_below",
            "in",
            "not_in"
          ]
        },
        "value": {
          "type": [
            "string",
            "number",
            "boolean",
            "array"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "riskControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "position-sizing",
            "stop-loss",
            "time-stop",
            "cooldown",
            "daily-loss-limit",
            "exposure-cap",
            "liquidity-filter"
          ]
        },
        "value": {
          "type": [
            "string",
            "number",
            "boolean"
          ]
        }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "metric": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "value": {
          "type": [
            "string",
            "number",
            "boolean"
          ]
        }
      }
    },
    "assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "impact": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "observedAt",
        "summary"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokenAddress",
        "symbol",
        "name",
        "venueUrl"
      ],
      "properties": {
        "tokenAddress": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        },
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "venueUrl": {
          "type": "string",
          "format": "uri"
        },
        "marketCapUsd": {
          "type": "number",
          "minimum": 0
        },
        "volume24hUsd": {
          "type": "number",
          "minimum": 0
        },
        "volume4hUsd": {
          "type": "number",
          "minimum": 0
        },
        "holders": {
          "type": "number",
          "minimum": 0
        },
        "bondingProgress": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "discoveryFeeds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "newLaunches",
              "volumeLeaders",
              "hot",
              "dexMigrated"
            ]
          }
        },
        "selectionBucket": {
          "type": "string",
          "enum": [
            "safe2ape",
            "mediumRisk",
            "gemHunt"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "graduated": {
          "type": "boolean"
        },
        "launchStage": {
          "type": "string",
          "enum": [
            "new",
            "migrated"
          ]
        },
        "categoryScore": {
          "type": "number"
        }
      }
    },
    "brainReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "provider",
        "status",
        "finalVerdict",
        "strategyThesis",
        "learning",
        "agents"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "off",
            "single-agent",
            "multi-agent"
          ]
        },
        "provider": {
          "type": "string",
          "enum": [
            "deterministic-generator",
            "local-rules",
            "openai-compatible"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "approved",
            "blocked",
            "advisory-only"
          ]
        },
        "finalVerdict": {
          "type": "string",
          "enum": [
            "approve",
            "wait",
            "reject"
          ]
        },
        "strategyThesis": {
          "type": "string",
          "minLength": 1
        },
        "learning": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policyVersion",
            "source",
            "appliedLessonIds",
            "summary"
          ],
          "properties": {
            "policyVersion": {
              "type": "string",
              "minLength": 1
            },
            "source": {
              "type": "string",
              "minLength": 1
            },
            "appliedLessonIds": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "summary": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/brainAgentReview"
          }
        }
      }
    },
    "brainAgentReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "model",
        "verdict",
        "confidence",
        "summary",
        "reasons",
        "appliedLessonIds"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "strategy",
            "safety",
            "social",
            "gatekeeper"
          ]
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "verdict": {
          "type": "string",
          "enum": [
            "approve",
            "wait",
            "reject"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "appliedLessonIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
