{
  "name": "4lpha-agent-skill",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "4lpha": "./bin/4lpha-agent-skill.js",
    "4lpha-agent-skill": "./bin/4lpha-agent-skill.js",
    "4lphacli": "./bin/4lpha-agent-skill.js",
    "fourmeme-skill": "./bin/4lpha-agent-skill.js"
  },
  "scripts": {
    "cli": "tsx scripts/agent-skill-cli.ts",
    "demo": "npm run cli -- example generate",
    "generate:cmc-strategy": "tsx scripts/generate-cmc-strategy.ts",
    "generate:bstocks-strategy": "tsx scripts/generate-bstocks-strategy.ts",
    "generate:fourmeme-proposed-fixture": "tsx scripts/generate-fourmeme-proposed-fixture.ts",
    "judge:live": "npm run skill:probe -- --plain && npm run demo -- --cmc-provider agent-hub-mcp --plain && npm run cli -- strategy validate examples/generated/cmc-market-regime.strategy.json --plain",
    "judge:replay": "npm run generate:fourmeme-proposed-fixture && npm run replay:fourmeme-fixture && npm run replay:fourmeme-pack && npm run validate:examples && npm run validate:judge-readiness",
    "judge:empirical": "npm run validate:cmc-skill-proof && npm run replay:fourmeme-real && npm run backtest:fourmeme-real && npm run validate:judge-readiness:strict",
    "capture:fourmeme-real": "tsx scripts/capture-fourmeme-real.ts",
    "replay:fourmeme-fixture": "tsx scripts/replay-fourmeme-fixture.ts",
    "replay:fourmeme-pack": "tsx scripts/replay-fourmeme-pack.ts",
    "replay:fourmeme-real": "tsx scripts/replay-fourmeme-real.ts",
    "backtest:fourmeme-real": "tsx scripts/backtest-fourmeme-real.ts",
    "skill:proof:import": "tsx scripts/import-cmc-skill-proof.ts",
    "skill:proof:live": "tsx scripts/probe-live-cmc-skill-proof.ts",
    "skill:proof:preflight": "tsx scripts/probe-live-cmc-skill-proof.ts --preflight-only",
    "skill:probe": "tsx scripts/probe-skill-marketplace.ts",
    "skill:route": "tsx scripts/route-skill.ts",
    "test:skill-router": "tsx tests/skill-router.smoke.ts",
    "test:token-info": "tsx tests/token-info.smoke.ts",
    "test:fourmeme-brain": "tsx tests/fourmeme-brain.smoke.ts",
    "test:bstocks-brain": "tsx tests/bstocks-brain.smoke.ts",
    "typecheck": "tsc --noEmit",
    "validate:examples": "tsx scripts/validate-examples.ts",
    "validate:cmc-skill-proof": "tsx scripts/validate-cmc-skill-proof.ts",
    "validate:judge-readiness": "tsx scripts/validate-judge-readiness.ts",
    "validate:judge-readiness:strict": "tsx scripts/validate-judge-readiness.ts --strict-real",
    "check": "npm run typecheck && npm run skill:route -- --plain && npm run skill:probe -- --plain && npm run test:skill-router && npm run test:fourmeme-brain && npm run test:bstocks-brain && npm run test:token-info && npm run replay:fourmeme-fixture && npm run replay:fourmeme-pack && npm run validate:examples && npm run validate:judge-readiness"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "dotenv": "17.4.2",
    "tsx": "4.22.4"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "typescript": "6.0.3"
  }
}
