# CoinMarketCap / Agent Hub
CMC_API_KEY=your-cmc-api-key
CMC_DATA_PROVIDER=rest

# Optional strategy brain.
# Defaults to local-rules so the demo works without an LLM API key.
# Set LLM_API_KEY only when using --brain-provider openai-compatible.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini

FOURMEME_BRAIN_MODE=multi-agent
FOURMEME_BRAIN_PROVIDER=local-rules
BSTOCKS_BRAIN_MODE=multi-agent
BSTOCKS_BRAIN_PROVIDER=local-rules

# BNBAgent SDK
BNBAGENT_NETWORK=bsc-testnet
BNBAGENT_AGENT_NAME=fourmeme-strategy-skill
BNBAGENT_AGENT_DESCRIPTION=Four.Meme-focused BNB strategy skill
BNBAGENT_AGENT_ENDPOINT=https://example.com/erc8183/status
BNBAGENT_ENDPOINT_NAME=ERC-8183
BNBAGENT_ENDPOINT_VERSION=0.1.0
BNBAGENT_ENDPOINT_CAPABILITIES=
BNBAGENT_AGENT_IMAGE=
BNBAGENT_SUPPORTED_TRUST=
WALLET_PASSWORD=change-me
PRIVATE_KEY=0xyour-private-key
WALLET_ADDRESS=
BNBAGENT_WALLETS_DIR=
