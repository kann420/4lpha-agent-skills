{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4lpha.tech/schemas/bstocks/bstocks-universe.schema.json",
  "title": "BstocksUniverse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "issuer",
    "venue",
    "venueUrl",
    "selectionUniverse"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "issuer": {
      "type": "string",
      "const": "bStocks"
    },
    "venue": {
      "type": "string",
      "const": "pancakeswap-stocks"
    },
    "venueUrl": {
      "type": "string",
      "format": "uri"
    },
    "selectionUniverse": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cmcId",
          "contractAddress",
          "symbol",
          "displayName"
        ],
        "properties": {
          "cmcId": {
            "type": "integer",
            "minimum": 1
          },
          "contractAddress": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]{40}$"
          },
          "symbol": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
